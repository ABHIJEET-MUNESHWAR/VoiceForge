{
  "name": "voiceforge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.7.0",
  "description": "Production-grade voice AI agent that answers calls and books home-service jobs (Twilio + Deepgram + ElevenLabs behind ports).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server-entry.ts",
    "start": "node dist/server-entry.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
