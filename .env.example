# VoiceForge configuration (all optional; defaults keep it fully runnable offline)
PORT=4100
LOG_LEVEL=info

# Voice stack: `mock` (default, deterministic, no network) or `live`.
VOICE_PROVIDER=mock

# Per-turn latency budget for STT/TTS calls (ms).
TURN_TIMEOUT_MS=2500
# Caller turns before escalating to a human.
MAX_TURNS=12

AGENT_NAME=Ivy
COMPANY_NAME=BrightHome Services

# --- Live provider credentials (only needed when VOICE_PROVIDER=live) ---
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
